rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: stats
    // Document ID: global
    // Fields:
    //   - appliedCount: number (required) - Total applications
    //   - lastActivity: map (optional) - { name: string, location: string, timestamp: number }
    //
    // Collection: leads
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required)
    //   - email: string (required, email format)
    //   - company: string (optional)
    //   - useCase: string (optional)
    //   - timestamp: number (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "namanrungta4@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // GlobalStats collection
    match /GlobalStats/global {
      allow read: if true; // Publicly readable for the counter
      
      // Allow anyone to increment the counter by 1
      allow create: if hasOnlyAllowedFields(['applicationCount']) && request.resource.data.applicationCount is number;
      allow update: if 
        hasOnlyAllowedFields(['applicationCount']) &&
        request.resource.data.applicationCount == resource.data.applicationCount + 1;
    }

    // Leads collection
    match /leads/{leadId} {
      allow create: if hasOnlyAllowedFields(['name', 'email', 'company', 'useCase', 'timestamp']) &&
                      request.resource.data.name is string &&
                      request.resource.data.email is string &&
                      request.resource.data.timestamp is number;
      allow read, update, delete: if isAdmin(); // Only admin can see leads
    }

    // Users collection (for roles)
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }
  }
}
