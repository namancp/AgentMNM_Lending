{
  "entities": {
    "GlobalStats": {
      "title": "Global Stats",
      "description": "Stores the global application count.",
      "type": "object",
      "properties": {
        "applicationCount": {
          "type": "number",
          "description": "The current total number of applications."
        }
      },
      "required": ["applicationCount"]
    },
    "Lead": {
      "title": "Lead",
      "description": "A signup lead from the beta application form.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "company": { "type": "string" },
        "useCase": { "type": "string" },
        "timestamp": { "type": "number" }
      },
      "required": ["name", "email", "timestamp"]
    }
  },
  "firestore": {
    "/GlobalStats/global": {
      "schema": "GlobalStats",
      "description": "The single document containing global application statistics."
    },
    "/leads/{leadId}": {
      "schema": "Lead",
      "description": "A collection of all beta application leads."
    }
  }
}
